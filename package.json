{
  "name": "celalyze",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -- pnpm --filter web dev",
    "build": "dotenvx run -- pnpm --filter web build",
    "lint": "dotenvx run -- pnpm --filter web lint",
    "test:contracts": "dotenvx run -- forge test --root apps/contracts",
    "video:dev": "npx remotion preview apps/web/src/remotion/index.ts",
    "video:render": "npx remotion render apps/web/src/remotion/index.ts CelalyzePresentation out/presentation.mp4"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.15.1"
  }
}
